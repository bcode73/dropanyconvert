{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dropanyconvert.com/schemas/tool.schema.json",
  "title": "DropAnyConvert Tool Definition",
  "type": "object",
  "required": [
    "schemaVersion",
    "toolId",
    "slug",
    "name",
    "category",
    "engine",
    "engineFn",
    "inputFormats",
    "outputFormats",
    "batch",
    "runtime",
    "seo",
    "faq",
    "capabilities"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version this tool was authored against.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "toolId": {
      "type": "string",
      "description": "Unique identifier. kebab-case. Must be globally unique.",
      "pattern": "^[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "description": "URL slug. Used for routing. Must be globally unique.",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "object",
      "description": "Localized display name.",
      "required": ["en"],
      "additionalProperties": { "type": "string" }
    },
    "tagline": {
      "type": "object",
      "description": "Short localized tagline displayed beneath the tool name.",
      "required": ["en"],
      "additionalProperties": { "type": "string" }
    },
    "category": {
      "type": "string",
      "description": "Category id from categories.json.",
      "enum": ["image", "pdf", "video", "audio", "text", "developer", "ai-development"]
    },
    "engine": {
      "type": "string",
      "description": "Engine module directory.",
      "enum": ["image_engine", "pdf_engine", "video_engine", "audio_engine", "text_engine", "developer_engine", "screenshot_ai_engine"]
    },
    "engineFn": {
      "type": "string",
      "description": "Name of the exported function within the engine."
    },
    "inputFormats": {
      "type": "array",
      "description": "Accepted input MIME types or extensions.",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "outputFormats": {
      "type": "array",
      "description": "Possible output formats.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ext", "mime", "label"],
        "properties": {
          "ext": { "type": "string" },
          "mime": { "type": "string" },
          "label": { "type": "string" },
          "default": { "type": "boolean" }
        }
      }
    },
    "batch": {
      "type": "object",
      "required": ["supported"],
      "properties": {
        "supported": { "type": "boolean" },
        "maxFiles": { "type": "integer", "minimum": 1 },
        "zipOutput": { "type": "boolean" }
      },
      "if": { "properties": { "supported": { "const": true } } },
      "then": { "required": ["supported", "maxFiles"] }
    },
    "runtime": {
      "type": "string",
      "enum": ["browser", "hybrid", "cloud"]
    },
    "runtimeHints": {
      "type": "object",
      "description": "Optional hints consumed by the runtime layer.",
      "properties": {
        "wasmModule": { "type": "string" },
        "workerScript": { "type": "string" },
        "memoryBudgetMb": { "type": "integer" },
        "preferOffscreenCanvas": { "type": "boolean" },
        "showVariantPicker": { "type": "boolean" },
        "limitation": { "type": "string" },
        "cloudProvider": { "type": "string" },
        "requiresWorker": { "type": "boolean" },
        "fallbackRuntime": { "type": "string", "enum": ["browser", "hybrid", "cloud"] },
        "maxFileSizeMb": { "type": "integer", "minimum": 1 }
      }
    },
    "uiGroup": {
      "type": "string",
      "description": "UI rendering group: 'conversion' shows variant picker, 'utility' shows related utilities, 'developer' shows the text-editor dev tool UI.",
      "enum": ["conversion", "utility", "developer", "ai-screenshot"]
    },
    "devOptions": {
      "type": "object",
      "description": "Developer tool UI configuration consumed by developer-runtime.js.",
      "properties": {
        "inputPlaceholder": { "type": "string" },
        "sampleInput": { "type": "string" },
        "outputLabel": { "type": "string" },
        "runButtonLabel": { "type": "string" },
        "outputType": { "type": "string" },
        "inputType": { "type": "string" },
        "livePreview": { "type": "boolean" },
        "downloadExt": { "type": "string" },
        "downloadMime": { "type": "string" },
        "testInput": { "type": "string" },
        "extraOptions": { "type": "array" }
      }
    },
    "capabilities": {
      "type": "array",
      "description": "Feature flags advertising what this tool supports.",
      "items": {
        "type": "string",
        "enum": [
          "batch",
          "drag-and-drop",
          "clipboard-paste",
          "preview",
          "download-zip",
          "mobile-supported",
          "large-files",
          "quality-control",
          "resize",
          "crop",
          "rotate",
          "flip",
          "watermark",
          "text-input",
          "text-output",
          "future-cloud-support",
          "merge",
          "split",
          "reorder",
          "rotate-pages",
          "extract-pages",
          "compress",
          "watermark-doc",
          "password-protect",
          "remove-password",
          "ocr",
          "metadata-edit",
          "form-extract",
          "thumbnail-generation",
          "page-selection",
          "page-thumbnails",
          "convert-to-pdf",
          "convert-from-pdf",
          "ai-enhance",
          "image-dpi",
          "metadata-read",
          "screenshot-upload",
          "stream-output",
          "copy-code",
          "download-code",
          "regenerate",
          "premium-required",
          "vision-ai",
          "multi-provider",
          "compare-generations",
          "generation-history"
        ]
      }
    },
    "seo": {
      "type": "object",
      "required": ["primaryKeyword", "title", "description"],
      "properties": {
        "primaryKeyword": { "type": "string" },
        "secondaryKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "title": {
          "type": "object",
          "required": ["en"],
          "additionalProperties": { "type": "string" }
        },
        "description": {
          "type": "object",
          "required": ["en"],
          "additionalProperties": { "type": "string" }
        },
        "h1": {
          "type": "object",
          "required": ["en"],
          "additionalProperties": { "type": "string" }
        },
        "intro": {
          "type": "object",
          "required": ["en"],
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "faq": {
      "type": "array",
      "description": "FAQ items. Rendered as FAQPage schema.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "object",
            "required": ["en"],
            "additionalProperties": { "type": "string" }
          },
          "answer": {
            "type": "object",
            "required": ["en"],
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "features": {
      "type": "array",
      "description": "Marketing bullet points shown on the tool page.",
      "items": {
        "type": "object",
        "required": ["icon", "title", "description"],
        "properties": {
          "icon": { "type": "string" },
          "title": {
            "type": "object",
            "required": ["en"],
            "additionalProperties": { "type": "string" }
          },
          "description": {
            "type": "object",
            "required": ["en"],
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "relatedTools": {
      "type": "array",
      "description": "Explicit related tool slugs. Boosts auto-generated related list.",
      "items": { "type": "string" }
    },
    "requiresLogin": {
      "type": "boolean",
      "description": "If true, user must be logged in to use this tool."
    },
    "requiresPremium": {
      "type": "boolean",
      "description": "If true, tool requires a paid plan."
    },
    "requiresCloud": {
      "type": "boolean",
      "description": "If true, tool requires server-side cloud runtime."
    },
    "aiProvider": {
      "type": "string",
      "description": "Default AI provider for this tool.",
      "enum": ["deepseek", "openai", "anthropic", "gemini", "openrouter", "ollama"]
    },
    "creditsPerUse": {
      "type": "integer",
      "description": "Credits deducted per generation.",
      "minimum": 0
    },
    "lastUpdated": {
      "type": "string",
      "description": "ISO 8601 date string for when this tool definition was last updated.",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
